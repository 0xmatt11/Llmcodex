# Service
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
SQLITE_PATH=./data/bridge.sqlite
BRIDGE_PUBLIC_BASE_URL=https://bridge.example.com

# Discord
DISCORD_TOKEN=replace-with-discord-bot-token
DISCORD_CHANNEL_ID=123456789012345678

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ X TRANSPORT MENU                                                          │
# │ Choose exactly one transport:                                             │
# │   selenium = default/free path using a logged-in browser session          │
# │   api      = official paid X API path using OAuth2 user-context token     │
# └───────────────────────────────────────────────────────────────────────────┘
X_TRANSPORT=selenium

# Shared X polling/formatting settings
X_POLL_INTERVAL_MS=15000
X_POLL_LIMIT=50
X_MAX_ATTACHMENT_LINKS=4

# Option 1: Selenium / X web UI transport. Required when X_TRANSPORT=selenium.
# Log in once with this browser profile, or provide exported X cookies in
# X_COOKIES_JSON. Keep both private.
X_GROUP_DM_URL=https://x.com/messages/replace-with-group-dm-id
X_SELF_USER_ID=your-x-display-name-or-handle-as-rendered-in-dm
X_BROWSER_USER_DATA_DIR=./browser-data
X_BROWSER_HEADLESS=true
X_BROWSER_NO_SANDBOX=true
CHROME_BIN=/usr/bin/chromium-browser
# X_COOKIES_JSON=[{"name":"auth_token","value":"...","domain":".x.com","path":"/","secure":true,"httpOnly":true}]
X_COOKIE_BOOTSTRAP_URL=https://x.com
X_MESSAGE_SELECTOR=[data-testid="messageEntry"]
X_COMPOSER_SELECTOR=[data-testid="dmComposerTextInput"]
X_SEND_BUTTON_SELECTOR=[data-testid="dmComposerSendButton"]
X_VISIBLE_MESSAGE_SCAN_LIMIT=100
X_READY_TIMEOUT_MS=30000
X_IMPLICIT_WAIT_MS=250
X_PAGE_LOAD_TIMEOUT_MS=60000
X_SCRIPT_TIMEOUT_MS=30000
X_SEND_ATTEMPTS=3

# Option 2: Official X API transport. Required only when X_TRANSPORT=api.
# Needs an X developer app/account tier with DM read/write access.
X_ACCESS_TOKEN=replace-with-oauth2-user-access-token
X_DM_CONVERSATION_ID=replace-with-group-dm-conversation-id
X_API_BASE_URL=https://api.x.com/2
