# Service
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
SQLITE_PATH=./data/bridge.sqlite
BRIDGE_PUBLIC_BASE_URL=https://bridge.example.com

# Discord
DISCORD_TOKEN=replace-with-discord-bot-token
DISCORD_CHANNEL_ID=123456789012345678

# X / Twitter client mode: api (default) or selenium.
# api uses OAuth 2.0 user-context token with dm.read, dm.write, users.read, tweet.read scopes.
# selenium uses a remote Selenium/WebDriver browser session instead of the X API.
X_CLIENT_MODE=api
X_DM_CONVERSATION_ID=replace-with-group-dm-conversation-id
X_POLL_INTERVAL_MS=15000
X_POLL_LIMIT=50
X_MAX_ATTACHMENT_LINKS=4

# X API mode only. Prefer a short-lived access token plus your external secret manager/token refresh job.
X_ACCESS_TOKEN=replace-with-oauth2-user-access-token
X_API_BASE_URL=https://api.x.com/2

# Selenium mode only. The browser must already be authenticated to X/Twitter, usually via a profile dir
# mounted into the Selenium browser container or by using a remote session that preserves login state.
X_SELENIUM_REMOTE_URL=http://localhost:4444/wd/hub
X_SELENIUM_BROWSER=chrome
X_SELENIUM_HEADLESS=true
X_SELENIUM_PROFILE_DIR=
X_SELENIUM_BASE_URL=https://x.com
X_SELENIUM_DM_URL=
X_SELENIUM_SELF_USER_ID=selenium-self
X_SELENIUM_EVENT_SELECTOR=[data-testid="messageEntry"]
X_SELENIUM_EVENT_ID_ATTRIBUTE=data-message-id
X_SELENIUM_MESSAGE_TEXT_SELECTOR=[data-testid="tweetText"], [dir="auto"]
X_SELENIUM_SENDER_SELECTOR=[data-testid="User-Name"], [role="link"][href^="/"]
X_SELENIUM_OWN_MESSAGE_SELECTOR=
X_SELENIUM_ATTACHMENT_SELECTOR=a[href^="http"]
X_SELENIUM_MESSAGE_INPUT_SELECTOR=[data-testid="dmComposerTextInput"]
X_SELENIUM_SEND_BUTTON_SELECTOR=[data-testid="dmComposerSendButton"]
X_SELENIUM_WAIT_TIMEOUT_MS=15000
X_SELENIUM_CAPABILITIES_JSON=
