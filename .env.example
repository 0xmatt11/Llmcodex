# Service
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
SQLITE_PATH=./data/bridge.sqlite
BRIDGE_PUBLIC_BASE_URL=https://bridge.example.com

# Discord
DISCORD_TOKEN=replace-with-discord-bot-token
DISCORD_CHANNEL_ID=123456789012345678

# X / Twitter OAuth 2.0 user-context token with dm.read, dm.write, users.read, tweet.read scopes.
# Prefer a short-lived access token plus your external secret manager/token refresh job.
X_ACCESS_TOKEN=replace-with-oauth2-user-access-token
X_DM_CONVERSATION_ID=replace-with-group-dm-conversation-id
X_API_BASE_URL=https://api.x.com/2
X_POLL_INTERVAL_MS=15000
X_POLL_LIMIT=50
X_MAX_ATTACHMENT_LINKS=4
